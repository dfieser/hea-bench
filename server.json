{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.dfieser/hea-bench",
  "title": "HEA-Bench",
  "description": "High-entropy alloy and oxide descriptors and phase-prediction rules, with provenance.",
  "version": "2.0.8",
  "repository": {
    "url": "https://github.com/dfieser/hea-bench",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "hea-bench",
      "version": "2.0.8",
      "runtimeHint": "uvx",
      "runtimeArguments": [
        { "type": "named", "name": "--from", "value": "hea-bench[mcp]" },
        { "type": "positional", "value": "hea-bench-mcp" }
      ],
      "transport": { "type": "stdio" }
    }
  ]
}
